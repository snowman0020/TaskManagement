# development | production
# In production the app refuses to start with the default JWT_SECRET / ADMIN_PASSWORD below.
ENVIRONMENT=development

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=taskmanagement

# Auth — REQUIRED to change for production (a known secret lets anyone forge admin tokens)
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default seeded admin account — REQUIRED to change for production
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

# CORS (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
